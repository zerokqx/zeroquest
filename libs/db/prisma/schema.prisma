// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum LegalDocumentType {
  PRIVACY
  PUBLIC
  TERMS
}

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PROCESSING
  WAITING_FOR_CONFIRMATION
  SUCCEEDED
  FAILED
  CANCELED
  REFUND_PENDING
  REFUNDED
}

enum RefundStatus {
  PENDING
  APPROVE
  REJECTED
}

enum WalletHistoryType {
  CREDIT
  DEBIT
  BONUS
  REFUND
}

enum SubscribeStatus {
  STOPPED
  ACTIVE
  PENDING
}

model ClientType {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("client_types")
}

model Session {
  id               String     @id @default(cuid())
  userAgentHash    String     @map("user_agent_hash")
  clientType       ClientType @relation(fields: [clientTypeId], references: [id], onDelete: Cascade)
  clientTypeId     Int        @map("client_type_id")
  refreshTokenJti  String     @map("refrest_token_jti")
  refreshTokenHash String     @map("refresh_token_hash")

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  @@unique([id, userId])
  @@map("sessions")
}

model Refund {
  id     Int          @id @default(autoincrement())
  status RefundStatus @default(PENDING)

  payment   Payment @relation(fields: [paymentId], references: [id])
  paymentId Int     @unique @map("payment_id")

  @@map("refunds")
}

model Inbound {
  id        Int     @id @default(autoincrement())
  enable    Boolean @default(true)
  name      String
  inboundId Int     @unique @map("inbount_id")
  plans     Plan[]

  @@map("inbounds")
}

model Plan {
  id                Int         @id @default(autoincrement())
  name              String      @unique
  isSpecial         Boolean     @default(false) @map("is_special")
  discountedPercent Decimal     @default(0.0) @map("discounted_percent") @db.Decimal(5, 2)
  features          String?
  price             Int
  description       String?
  totalGb           Int         @default(30)
  payments          Payment[]
  subscribes        Subscribe[]
  inbound           Inbound     @relation(fields: [inboundId], references: [id])
  inboundId         Int         @map("inbound_id")
  duratationDays    Int         @map("durataton_days")

  @@map("plans")
}

model Review {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique @map("user_id")
  content   String
  rating    Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("reviews")
}

model Payment {
  id                Int           @id @default(autoincrement())
  providerPaymentId String        @unique @map("provider_payment_id")
  status            PaymentStatus @default(PENDING)
  currency          String        @default("RUB")
  value             Int
  createdAt         DateTime      @default(now()) @map("created_at")
  description       String?
  user              User          @relation(fields: [userId], references: [id])
  userId            String        @map("user_id")
  refund            Refund?
  confirmationUrl   String        @map("confirmation_url")
  plan              Plan?         @relation(fields: [planId], references: [id])
  planId            Int?

  @@unique([id, userId])
  @@map("payments")
}

model Subscribe {
  id              String          @id @default(cuid())
  name            String          @unique
  vlessLink       String          @map("vless_link")
  user            User            @relation(fields: [userId], references: [id])
  vlessClientId   String          @map("vless_client_id")
  userId          String          @map("user_id")
  email           String          @default(uuid())
  nextPaymentDate DateTime        @map("next_payment_date")
  status          SubscribeStatus @default(PENDING)
  expiresAt       DateTime        @map("expires_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  plan            Plan            @relation(fields: [planId], references: [id])
  planId          Int             @map("plan_id")
  totalGb         Int             @map("total_gb")

  @@unique([id, userId])
  @@map("subscribers")
}

model User {
  id               String             @id @default(cuid())
  login            String             @unique
  telegramId       Int?               @map("telegram_id")
  passwordHash     String             @map("password_hash")
  subscribes       Subscribe[]
  isBanned         Boolean            @default(false) @map("is_banned")
  role             UserRole?          @default(USER)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  payments         Payment[]
  sessions         Session[]
  review           Review?
  canComment       Boolean            @default(true) @map("can_comment")
  wallet           Wallet             @relation(fields: [walletId], references: [id])
  walletId         String             @unique @map("wallet_id")
  legalAcceptances LegalAcceptances[]

  @@map("users")
}

model Wallet {
  id              String          @id @default(cuid())
  held            Int             @default(0)
  balance         Int             @default(0)
  user            User?
  walletHistories WalletHistory[]

  @@map("wallet")
}

model WalletHistory {
  id        String            @id @default(cuid())
  amount    Int
  balance   Int
  type      WalletHistoryType
  createdAt DateTime          @default(now()) @map("created_at")
  walletId  String @map("wallet_id")
  wallet    Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_history")
}

model LegalDocument {
  id               Int                @id @default(autoincrement())
  type             LegalDocumentType
  version          DateTime           @default(now())
  content          String
  legalAcceptances LegalAcceptances[]

  @@map("legal_documents")
}

model LegalAcceptances {
  user            User          @relation(fields: [userId], references: [id])
  userId          String        @map("user_id")
  legalDocumentId Int           @map("legal_document_id")
  legalDocument   LegalDocument @relation(fields: [legalDocumentId], references: [id])

  @@id([userId, legalDocumentId])
  @@map("legal_acceptances")
}
