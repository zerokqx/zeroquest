{
  "name": "@zeroquest/api",
  "version": "0.0.1",
  "moduleResolution": "node16",
  "module": "commonjs",
  "target": "esnext",
  "private": true,
  "nx": {
    "targets": {
      "ngrok:run": {
        "executor": "nx:run-commands",
        "options": {
          "command": "ngrok http $API_PORT --log=stdout --log-format=logfmt",
          "cwd": "apps/api",
          "envFile": ".env"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "defaultConfiguration": "development",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "cwd": "apps/api"
        },
        "configurations": {
          "production": {
            "args": [
              "--node-env=production"
            ]
          },
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/api/dist/package.json",
          "{workspaceRoot}/apps/api/dist/bun.lock"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/api/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@zeroquest/api:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {},
          "production": {
            "buildTarget": "@zeroquest/api:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@bull-board/api": "^6.21.0",
    "@bull-board/nestjs": "^6.21.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/mapped-types": "*",
    "@zeroquest/config": "workspace:*",
    "@zeroquest/types": "workspace:*",
    "@zeroquest/db": "workspace:*",
    "@zeroquest/nest-shared": "workspace:*",
    "@zeroquest/converters": "workspace:*",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.4",
    "cache-manager": "^7.2.8",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-formidable": "^1.2.0",
    "express-session": "^1.19.0",
    "ioredis": "^5.10.1",
    "nest-winston": "^1.10.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
